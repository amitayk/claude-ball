{
  "name": "claude-ball",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vibe-coding soccer: humans design the brain, Claude only writes the code.",
  "workspaces": [
    "packages/*",
    "templates/brain-starter"
  ],
  "scripts": {
    "coach": "npm run coach --workspace @claude-ball/brain-starter",
    "match": "tsx packages/runner/src/cli.ts",
    "viewer": "tsx packages/viewer/serve.ts",
    "demo": "npm run match -- formation chaser --seed 7 --out packages/viewer/replay.json && npm run viewer",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "api": "tsx packages/api/src/server.ts",
    "web": "tsx apps/web/serve.ts",
    "arena": "npm run api & npm run web",
    "new": "node scripts/new-bot.mjs",
    "build:web-sim": "esbuild apps/web/_sim-src.ts --bundle --format=esm --platform=browser --outfile=apps/web/sim.bundle.js"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "esbuild": "^0.24.0"
  }
}
